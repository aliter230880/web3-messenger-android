{
  "appId": "andr.web3gram",
  "appName": "Web3Gram",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#1a1d23",
      "androidSplashResourceName": "splash"
    }
  }
}
