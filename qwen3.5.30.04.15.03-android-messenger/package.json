    "ethers": "^5.7.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "process": "^0.11.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "3.4.0",
